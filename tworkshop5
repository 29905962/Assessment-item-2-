namespace Workshop4;

public static class InsertionSort
{
    // Task 2
    // Insertion Sort (ascending, in-place)

    // Counting rules:
    // - Comparisons: increment once per comparison with key
    // - Shifts count as swaps

    public static (int Comparisons, int Swaps) Sort(int[] data)
    {
        int comparisons = 0;
        int swaps = 0;

        for (int i = 1; i < data.Length; i++)
        {
            int key = data[i];
            int j = i - 1;

            while (j >= 0)
            {
                comparisons++;

                if (data[j] > key)
                {
                    data[j + 1] = data[j];

                    // Shift counts as swap
                    swaps++;

                    j--;
                }
                else
                {
                    break;
                }
            }

            data[j + 1] = key;
        }

        return (comparisons, swaps);
    }
}

