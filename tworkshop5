namespace Workshop4;

public static class SelectionSort
{
    // Task 1
    // Selection Sort (ascending, in-place)

    // Counting rules:
    // - Comparisons: increment once per value comparison
    // - Swaps: increment only for a real swap

    public static (int Comparisons, int Swaps) Sort(int[] data)
    {
        int comparisons = 0;
        int swaps = 0;

        for (int i = 0; i < data.Length - 1; i++)
        {
            int minIndex = i;

            for (int j = i + 1; j < data.Length; j++)
            {
                comparisons++;

                if (data[j] < data[minIndex])
                {
                    minIndex = j;
                }
            }

            // Only swap if needed
            if (minIndex != i)
            {
                (data[i], data[minIndex]) =
                    (data[minIndex], data[i]);

                swaps++;
            }
        }

        return (comparisons, swaps);
    }
}

